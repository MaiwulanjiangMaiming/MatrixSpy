{
  "name": "matrixspy",
  "displayName": "MatrixSpy",
  "description": "A powerful VS Code extension for exploring, visualizing, and exporting MATLAB .mat files. Supports all versions (v4-v7.3), image mat data, interactive plotting, and export to CSV/JSON/NumPy. Right-click any .mat file to open!",
  "version": "1.1.1",
  "publisher": "maiwulanjiangmaiming",
  "repository": {
    "type": "git",
    "url": "https://github.com/MaiwulanjiangMaiming/MatrixSpy.git"
  },
  "bugs": {
    "url": "https://github.com/MaiwulanjiangMaiming/MatrixSpy/issues"
  },
  "homepage": "https://github.com/MaiwulanjiangMaiming/MatrixSpy#readme",
  "license": "MIT",
  "keywords": [
    "matlab",
    "mat",
    "matrix",
    "data",
    "visualization",
    "viewer",
    "science",
    "research"
  ],
  "icon": "resources/Plugin.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Data Science",
    "Visualization"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "matrixspy.openFile",
        "title": "Open MAT File",
        "category": "MatrixSpy"
      },
      {
        "command": "matrixspy.exportCSV",
        "title": "Export to CSV",
        "category": "MatrixSpy"
      },
      {
        "command": "matrixspy.exportJSON",
        "title": "Export to JSON",
        "category": "MatrixSpy"
      },
      {
        "command": "matrixspy.refreshVariables",
        "title": "Refresh Variables",
        "category": "MatrixSpy",
        "icon": "$(refresh)"
      },
      {
        "command": "matrixspy.installDeps",
        "title": "Install Python Dependencies",
        "category": "MatrixSpy"
      },
      {
        "command": "matrixspy.openSample",
        "title": "Open Sample MAT File",
        "category": "MatrixSpy"
      },
      {
        "command": "matrixspy.showWelcome",
        "title": "Show Welcome Page",
        "category": "MatrixSpy"
      },
      {
        "command": "matrixspy.resetWelcome",
        "title": "Reset Welcome State",
        "category": "MatrixSpy"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "matrixspy",
          "title": "MatrixSpy",
          "icon": "resources/Sidebar.svg"
        }
      ]
    },
    "views": {
      "matrixspy": [
        {
          "id": "matrixspyVariables",
          "name": "Variables"
        }
      ]
    },
    "menus": {
      "explorer/context": [
        {
          "command": "matrixspy.openFile",
          "when": "resourceExtname == .mat",
          "group": "navigation"
        }
      ],
      "view/title": [
        {
          "command": "matrixspy.refreshVariables",
          "when": "view == matrixspyVariables",
          "group": "navigation"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "matrixspy.matFile",
        "displayName": "MatrixSpy",
        "selector": [
          {
            "filenamePattern": "*.mat"
          }
        ]
      }
    ],
    "configuration": {
      "title": "MatrixSpy",
      "properties": {
        "matrixspy.pythonPath": {
          "type": "string",
          "default": "python3",
          "description": "Path to Python executable"
        },
        "matrixspy.maxDataSize": {
          "type": "number",
          "default": 10000,
          "description": "Maximum data size to load (number of elements)"
        },
        "matrixspy.enableImage": {
          "type": "boolean",
          "default": true,
          "description": "Enable image mat data-specific features"
        }
      }
    },
    "walkthroughs": [
      {
        "id": "matrixspy.welcome",
        "title": "Get Started with MatrixSpy",
        "description": "Learn how to use MatrixSpy to explore and visualize MATLAB .mat files",
        "steps": [
          {
            "id": "install",
            "title": "Install Python Dependencies",
            "description": "MatrixSpy requires Python 3.8+ with scipy, numpy, h5py, and mat73 packages.\n[Install Dependencies](command:matrixspy.installDeps)",
            "media": {
              "markdown": "media/install.md"
            }
          },
          {
            "id": "open",
            "title": "Open a MAT File",
            "description": "There are three ways to open a .mat file:\n\n1. **Double-click** any `.mat` file in the Explorer\n2. **Right-click** a `.mat` file → \"Open MAT File\"\n3. Use Command Palette: `Cmd+Shift+P` → \"MatrixSpy: Open MAT File\"\n\n[Open Sample File](command:matrixspy.openSample)",
            "media": {
              "markdown": "media/open.md"
            }
          },
          {
            "id": "navigate",
            "title": "Navigate Variables",
            "description": "Use the **sidebar** to browse all variables in your MAT file.\n\n- Click on a variable to view its data\n- Expand structs to see nested fields\n- Use the tree navigation for multi-level structures",
            "media": {
              "markdown": "media/navigate.md"
            }
          },
          {
            "id": "visualize",
            "title": "Visualize Data",
            "description": "MatrixSpy automatically visualizes your data:\n\n- **1D arrays**: Line plots\n- **2D matrices**: Heatmaps or tables\n- **3D tensors**: Interactive slice viewer\n- **Complex numbers**: Magnitude/Phase display\n\nSwitch between **Image** and **Table** views using the tabs.",
            "media": {
              "markdown": "media/visualize.md"
            }
          },
          {
            "id": "export",
            "title": "Export Data",
            "description": "Export your data in multiple formats:\n\n- **CSV**: Right-click variable → \"Export to CSV\"\n- **JSON**: Right-click variable → \"Export to JSON\"\n- **NumPy**: Use Command Palette → \"MatrixSpy: Export to NumPy\"",
            "media": {
              "markdown": "media/export.md"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "20.10.0",
    "@types/vscode": "1.85.0",
    "@typescript-eslint/eslint-plugin": "6.13.0",
    "@typescript-eslint/parser": "6.13.0",
    "eslint": "8.54.0",
    "typescript": "5.3.2",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "await-lock": "^3.0.0"
  }
}
